{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/tools/:path*", "destination": "/tools/:path*/index.html" },
    { "source": "/best/:path*", "destination": "/best/:path*/index.html" },
    { "source": "/compare/:path*", "destination": "/compare/:path*/index.html" },
    { "source": "/trades/:path*", "destination": "/trades/:path*/index.html" },
    { "source": "/guides/:path*", "destination": "/guides/:path*/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/llms-full.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/feed.xml",
      "headers": [{ "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    }
  ]
}
